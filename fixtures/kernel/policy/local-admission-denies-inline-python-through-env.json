{
  "$schema": "../schema/policy.schema.json",
  "expected": {
    "kind": "output",
    "value": {
      "reasons": [
        "cli-tool source 'python3' uses inline code via '-c', which is rejected by strict workspace policy; move the program into a checked-in script and invoke that file instead"
      ],
      "status": "deny"
    }
  },
  "input": {
    "kind": "policy.admitLocalSkill",
    "options": {
      "executionPolicy": {
        "strictCliToolInlineCode": true
      }
    },
    "skill": {
      "name": "inline-python",
      "source": {
        "args": [
          "PYTHONPATH=.",
          "python3",
          "-c",
          "print('hi')"
        ],
        "command": "/usr/bin/env",
        "type": "cli-tool"
      }
    }
  },
  "name": "local-admission-denies-inline-python-through-env"
}
