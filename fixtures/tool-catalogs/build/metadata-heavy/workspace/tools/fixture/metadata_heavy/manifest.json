{
  "name": "fixture.metadata_heavy",
  "version": "0.0.1",
  "description": "Fixture tool with optional metadata.",
  "source": {
    "type": "cli-tool",
    "command": "node",
    "args": [
      "./run.mjs"
    ],
    "input_mode": "stdin",
    "timeout_seconds": 5
  },
  "inputs": {
    "path": {
      "type": "string",
      "required": true,
      "description": "Relative path to summarize."
    },
    "verbose": {
      "type": "boolean",
      "required": false,
      "default": false
    }
  },
  "scopes": [
    "fixture.metadata_heavy",
    "workspace.read"
  ],
  "risk": {
    "mutating": false
  },
  "runx": {
    "artifacts": {
      "wrap_as": "metadata_summary"
    },
    "idempotency": {
      "key": "fixture-metadata-heavy"
    }
  }
}
