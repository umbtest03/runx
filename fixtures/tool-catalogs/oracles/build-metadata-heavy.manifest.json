{
  "schema": "runx.tool.manifest.v1",
  "name": "fixture.metadata_heavy",
  "version": "0.0.1",
  "description": "Fixture tool with optional metadata.",
  "source": {
    "type": "cli-tool",
    "command": "node",
    "args": [
      "./run.mjs"
    ],
    "input_mode": "stdin",
    "timeout_seconds": 5
  },
  "inputs": {
    "path": {
      "type": "string",
      "required": true,
      "description": "Relative path to summarize."
    },
    "verbose": {
      "type": "boolean",
      "required": false,
      "default": false
    }
  },
  "scopes": [
    "fixture.metadata_heavy",
    "workspace.read"
  ],
  "risk": {
    "mutating": false
  },
  "runx": {
    "artifacts": {
      "wrap_as": "metadata_summary"
    },
    "idempotency": {
      "key": "fixture-metadata-heavy"
    }
  },
  "runtime": {
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "output": {
    "wrap_as": "metadata_summary"
  },
  "source_hash": "sha256:44f0cf7e5fa6c0b8942feb229dcd2e22aa4ce059ce5c4b31129e3338fc4d21a8",
  "schema_hash": "sha256:1916b0d20acea2e19a0a50a688925fe18ae1093c09d750f8c40be3bab5deb436",
  "toolkit_version": "0.1.4"
}
