{
  "name": "@runxhq/core",
  "version": "0.1.4",
  "description": "Runx pure kernel domains: parser, state machine, policy, executor contracts, receipts, registry, knowledge, config, and artifacts.",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./artifacts": {
      "types": "./dist/src/artifacts/index.d.ts",
      "import": "./dist/src/artifacts/index.js"
    },
    "./config": {
      "types": "./dist/src/config/index.d.ts",
      "import": "./dist/src/config/index.js"
    },
    "./executor": {
      "types": "./dist/src/executor/index.d.ts",
      "import": "./dist/src/executor/index.js"
    },
    "./knowledge": {
      "types": "./dist/src/knowledge/index.d.ts",
      "import": "./dist/src/knowledge/index.js"
    },
    "./marketplaces": {
      "types": "./dist/src/marketplaces/index.d.ts",
      "import": "./dist/src/marketplaces/index.js"
    },
    "./parser": {
      "types": "./dist/src/parser/index.d.ts",
      "import": "./dist/src/parser/index.js"
    },
    "./policy": {
      "types": "./dist/src/policy/index.d.ts",
      "import": "./dist/src/policy/index.js"
    },
    "./receipts": {
      "types": "./dist/src/receipts/index.d.ts",
      "import": "./dist/src/receipts/index.js"
    },
    "./registry": {
      "types": "./dist/src/registry/index.d.ts",
      "import": "./dist/src/registry/index.js"
    },
    "./tool-catalogs": {
      "types": "./dist/src/tool-catalogs/index.d.ts",
      "import": "./dist/src/tool-catalogs/index.js"
    },
    "./state-machine": {
      "types": "./dist/src/state-machine/index.d.ts",
      "import": "./dist/src/state-machine/index.js"
    }
  },
  "dependencies": {
    "@runxhq/contracts": "workspace:^0.2.3",
    "yaml": "^2.8.3"
  }
}
