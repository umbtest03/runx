      "types": "./dist/src/executor/index.d.ts",
      "import": "./dist/src/executor/index.js"
    },
    "./harness": {
      "types": "./dist/src/harness/index.d.ts",
      "import": "./dist/src/harness/index.js"
    },
    "./knowledge": {
      "types": "./dist/src/knowledge/index.d.ts",
      "import": "./dist/src/knowledge/index.js"
    },
    "./marketplaces": {
      "types": "./dist/src/marketplaces/index.d.ts",
      "import": "./dist/src/marketplaces/index.js"
    },
    "./mcp": {
      "types": "./dist/src/mcp/index.d.ts",
      "import": "./dist/src/mcp/index.js"
