{
  "name": "@runxhq/runtime-local",
  "version": "0.1.2",
  "description": "Runx local runtime: orchestration, harness execution, SDK host bridge, local receipts, and local process sandboxing.",
  "private": false,
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./harness": {
      "types": "./dist/src/harness/index.d.ts",
      "import": "./dist/src/harness/index.js"
    },
    "./runner-local": {
      "types": "./dist/src/runner-local/index.d.ts",
      "import": "./dist/src/runner-local/index.js"
    },
    "./sdk": {
      "types": "./dist/src/sdk/index.d.ts",
      "import": "./dist/src/sdk/index.js"
    },
    "./mcp": {
      "types": "./dist/src/mcp/index.d.ts",
      "import": "./dist/src/mcp/index.js"
    },
    "./tool-catalogs": {
      "types": "./dist/src/tool-catalogs/index.d.ts",
      "import": "./dist/src/tool-catalogs/index.js"
    }
  },
  "dependencies": {
    "@runxhq/contracts": "workspace:^0.2.4",
    "@runxhq/core": "workspace:^0.1.5",
    "yaml": "^2.8.3"
  }
}
