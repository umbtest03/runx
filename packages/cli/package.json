{
  "name": "@runxhq/cli",
  "version": "0.4.2",
  "description": "Runx CLI — governed runtime for agent skills, tools, chains, and packets.",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://github.com/runxhq/runx",
  "bugs": {
    "url": "https://github.com/runxhq/runx/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runxhq/runx.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "runx": "./bin/runx.js"
  },
  "files": [
    "LICENSE",
    "bin",
    "dist",
    "tools",
    "skills/VOICE.md",
    "skills/run.mjs",
    "skills/scafld/run.mjs"
  ],
  "scripts": {
    "runx": "tsx src/index.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./metadata": {
      "types": "./dist/src/metadata.d.ts",
      "import": "./dist/src/metadata.js"
    }
  },
  "dependencies": {
    "@runxhq/adapters": "workspace:^0.1.0",
    "@runxhq/authoring": "workspace:^0.1.1",
    "@runxhq/contracts": "workspace:^0.1.0",
    "@runxhq/core": "workspace:^0.1.0",
    "yaml": "^2.8.3"
  }
}
