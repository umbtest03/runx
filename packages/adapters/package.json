{
  "name": "@runxhq/adapters",
  "version": "0.1.2",
  "description": "Runx concrete runtime adapters.",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./a2a": {
      "types": "./dist/src/a2a/index.d.ts",
      "import": "./dist/src/a2a/index.js"
    },
    "./catalog": {
      "types": "./dist/src/catalog/index.d.ts",
      "import": "./dist/src/catalog/index.js"
    },
    "./agent": {
      "types": "./dist/src/agent/index.d.ts",
      "import": "./dist/src/agent/index.js"
    },
    "./cli-tool": {
      "types": "./dist/src/cli-tool/index.d.ts",
      "import": "./dist/src/cli-tool/index.js"
    },
    "./mcp": {
      "types": "./dist/src/mcp/index.d.ts",
      "import": "./dist/src/mcp/index.js"
    },
    "./runtime": {
      "types": "./dist/src/runtime.d.ts",
      "import": "./dist/src/runtime.js"
    }
  },
  "peerDependencies": {
    "@runxhq/core": "workspace:^0.1.1"
  },
  "peerDependenciesMeta": {
    "@runxhq/core": {
      "optional": true
    }
  }
}
