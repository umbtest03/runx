{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@runxhq/adapters": ["packages/adapters/src/index.ts"],
      "@runxhq/adapters/runtime": ["packages/adapters/src/runtime.ts"],
      "@runxhq/adapters/*": ["packages/adapters/src/*/index.ts"],
      "@runxhq/authoring": ["packages/authoring/src/index.ts"],
      "@runxhq/cli": ["packages/cli/src/index.ts"],
      "@runxhq/cli/*": ["packages/cli/src/*"],
      "@runxhq/contracts": ["packages/contracts/src/index.ts"],
      "@runxhq/core": ["packages/core/src/index.ts"],
      "@runxhq/core/*": ["packages/core/src/*/index.ts"],
      "@runxhq/host-adapters": ["packages/host-adapters/src/index.ts"],
      "@runxhq/runtime-local": ["packages/runtime-local/src/index.ts"],
      "@runxhq/runtime-local/*": ["packages/runtime-local/src/*/index.ts"]
    }
  }
}
