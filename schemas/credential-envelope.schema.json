{
  "$id": "https://runx.ai/spec/credential-envelope.schema.json",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "kind",
    "grant_id",
    "provider",
    "connection_id",
    "scopes",
    "material_ref"
  ],
  "properties": {
    "kind": {
      "const": "runx.credential-envelope.v1",
      "type": "string"
    },
    "grant_id": {
      "minLength": 1,
      "type": "string"
    },
    "provider": {
      "minLength": 1,
      "type": "string"
    },
    "connection_id": {
      "minLength": 1,
      "type": "string"
    },
    "scopes": {
      "type": "array",
      "items": {
        "minLength": 1,
        "type": "string"
      }
    },
    "grant_reference": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "grant_id",
        "scope_family",
        "authority_kind"
      ],
      "properties": {
        "grant_id": {
          "minLength": 1,
          "type": "string"
        },
        "scope_family": {
          "minLength": 1,
          "type": "string"
        },
        "authority_kind": {
          "anyOf": [
            {
              "const": "read_only",
              "type": "string"
            },
            {
              "const": "constructive",
              "type": "string"
            },
            {
              "const": "destructive",
              "type": "string"
            }
          ]
        },
        "target_repo": {
          "minLength": 1,
          "type": "string"
        },
        "target_locator": {
          "minLength": 1,
          "type": "string"
        }
      }
    },
    "material_ref": {
      "minLength": 1,
      "type": "string"
    }
  }
}
