{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.runx.dev/runx/list/v1.json",
  "x-runx-schema": "runx.list.v1",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "schema",
    "root",
    "requested_kind",
    "items"
  ],
  "properties": {
    "schema": {
      "const": "runx.list.v1",
      "type": "string"
    },
    "root": {
      "type": "string"
    },
    "requested_kind": {
      "anyOf": [
        {
          "const": "all",
          "type": "string"
        },
        {
          "const": "tools",
          "type": "string"
        },
        {
          "const": "skills",
          "type": "string"
        },
        {
          "const": "chains",
          "type": "string"
        },
        {
          "const": "packets",
          "type": "string"
        },
        {
          "const": "overlays",
          "type": "string"
        }
      ]
    },
    "items": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "kind",
          "name",
          "source",
          "path",
          "status"
        ],
        "properties": {
          "kind": {
            "anyOf": [
              {
                "const": "tool",
                "type": "string"
              },
              {
                "const": "skill",
                "type": "string"
              },
              {
                "const": "chain",
                "type": "string"
              },
              {
                "const": "packet",
                "type": "string"
              },
              {
                "const": "overlay",
                "type": "string"
              }
            ]
          },
          "name": {
            "type": "string"
          },
          "source": {
            "anyOf": [
              {
                "const": "local",
                "type": "string"
              },
              {
                "const": "workspace",
                "type": "string"
              },
              {
                "const": "dependencies",
                "type": "string"
              },
              {
                "const": "built-in",
                "type": "string"
              }
            ]
          },
          "path": {
            "type": "string"
          },
          "status": {
            "anyOf": [
              {
                "const": "ok",
                "type": "string"
              },
              {
                "const": "invalid",
                "type": "string"
              }
            ]
          },
          "diagnostics": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "emits": {
            "type": "array",
            "items": {
              "additionalProperties": false,
              "type": "object",
              "required": [
                "name"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "packet": {
                  "type": "string"
                }
              }
            }
          },
          "fixtures": {
            "minimum": 0,
            "type": "integer"
          },
          "harness_cases": {
            "minimum": 0,
            "type": "integer"
          },
          "steps": {
            "minimum": 0,
            "type": "integer"
          },
          "wraps": {
            "type": "string"
          }
        }
      }
    }
  }
}
