{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.runx.dev/runx/doctor/v1.json",
  "x-runx-schema": "runx.doctor.v1",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "schema",
    "status",
    "summary",
    "diagnostics"
  ],
  "properties": {
    "schema": {
      "const": "runx.doctor.v1",
      "type": "string"
    },
    "status": {
      "anyOf": [
        {
          "const": "success",
          "type": "string"
        },
        {
          "const": "failure",
          "type": "string"
        }
      ]
    },
    "summary": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "errors",
        "warnings",
        "infos"
      ],
      "properties": {
        "errors": {
          "minimum": 0,
          "type": "integer"
        },
        "warnings": {
          "minimum": 0,
          "type": "integer"
        },
        "infos": {
          "minimum": 0,
          "type": "integer"
        }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "id",
          "instance_id",
          "severity",
          "title",
          "message",
          "target",
          "location",
          "repairs"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "instance_id": {
            "type": "string"
          },
          "severity": {
            "anyOf": [
              {
                "const": "error",
                "type": "string"
              },
              {
                "const": "warning",
                "type": "string"
              },
              {
                "const": "info",
                "type": "string"
              }
            ]
          },
          "title": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "target": {
            "type": "object",
            "patternProperties": {
              "^(.*)$": {}
            }
          },
          "location": {
            "additionalProperties": false,
            "type": "object",
            "required": [
              "path"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "json_pointer": {
                "type": "string"
              }
            }
          },
          "evidence": {
            "type": "object",
            "patternProperties": {
              "^(.*)$": {}
            }
          },
          "repairs": {
            "type": "array",
            "items": {
              "additionalProperties": false,
              "type": "object",
              "required": [
                "id",
                "kind",
                "confidence",
                "risk",
                "requires_human_review"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "kind": {
                  "anyOf": [
                    {
                      "const": "create_file",
                      "type": "string"
                    },
                    {
                      "const": "replace_file",
                      "type": "string"
                    },
                    {
                      "const": "edit_yaml",
                      "type": "string"
                    },
                    {
                      "const": "edit_json",
                      "type": "string"
                    },
                    {
                      "const": "add_fixture",
                      "type": "string"
                    },
                    {
                      "const": "run_command",
                      "type": "string"
                    },
                    {
                      "const": "manual",
                      "type": "string"
                    }
                  ]
                },
                "confidence": {
                  "anyOf": [
                    {
                      "const": "low",
                      "type": "string"
                    },
                    {
                      "const": "medium",
                      "type": "string"
                    },
                    {
                      "const": "high",
                      "type": "string"
                    }
                  ]
                },
                "risk": {
                  "anyOf": [
                    {
                      "const": "low",
                      "type": "string"
                    },
                    {
                      "const": "medium",
                      "type": "string"
                    },
                    {
                      "const": "high",
                      "type": "string"
                    },
                    {
                      "const": "sensitive",
                      "type": "string"
                    }
                  ]
                },
                "path": {
                  "type": "string"
                },
                "json_pointer": {
                  "type": "string"
                },
                "contents": {
                  "type": "string"
                },
                "patch": {
                  "type": "string"
                },
                "command": {
                  "type": "string"
                },
                "requires_human_review": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
    }
  }
}
