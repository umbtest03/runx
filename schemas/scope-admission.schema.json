{
  "$id": "https://runx.ai/spec/scope-admission.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "decision_summary": {
      "type": "string"
    },
    "grant_id": {
      "minLength": 1,
      "type": "string"
    },
    "granted_scopes": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    },
    "reasons": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    },
    "requested_scopes": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    },
    "status": {
      "anyOf": [
        {
          "const": "allow",
          "type": "string"
        },
        {
          "const": "deny",
          "type": "string"
        }
      ]
    }
  },
  "required": [
    "status",
    "requested_scopes",
    "granted_scopes"
  ],
  "type": "object"
}
