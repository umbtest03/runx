{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runx.ai/spec/question.schema.json",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "id",
    "prompt",
    "required",
    "type"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "type": "string"
    },
    "prompt": {
      "minLength": 1,
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "required": {
      "type": "boolean"
    },
    "type": {
      "minLength": 1,
      "type": "string"
    }
  }
}
