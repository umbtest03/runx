{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runx.ai/spec/approval-gate.schema.json",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "id",
    "reason"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "type": "string"
    },
    "reason": {
      "minLength": 1,
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "summary": {
      "type": "object",
      "patternProperties": {
        "^(.*)$": {}
      }
    }
  }
}
