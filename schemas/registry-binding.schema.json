{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runx.ai/schemas/registry-binding.schema.json",
  "title": "runx upstream registry binding",
  "additionalProperties": true,
  "type": "object",
  "required": [
    "schema",
    "state",
    "skill",
    "upstream",
    "registry",
    "harness"
  ],
  "properties": {
    "schema": {
      "const": "runx.registry_binding.v1",
      "type": "string"
    },
    "state": {
      "anyOf": [
        {
          "const": "registry_binding_drafted",
          "type": "string"
        },
        {
          "const": "registry_bound",
          "type": "string"
        },
        {
          "const": "harness_verified",
          "type": "string"
        },
        {
          "const": "published",
          "type": "string"
        }
      ]
    },
    "skill": {
      "additionalProperties": true,
      "type": "object",
      "required": [
        "id",
        "name",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "upstream": {
      "additionalProperties": true,
      "type": "object",
      "required": [
        "host",
        "owner",
        "repo",
        "path",
        "commit",
        "blob_sha",
        "source_of_truth"
      ],
      "properties": {
        "host": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "commit": {
          "type": "string"
        },
        "blob_sha": {
          "type": "string"
        },
        "pr_url": {
          "type": "string"
        },
        "merged_at": {
          "type": "string"
        },
        "html_url": {
          "type": "string"
        },
        "raw_url": {
          "type": "string"
        },
        "source_of_truth": {
          "const": true,
          "type": "boolean"
        }
      }
    },
    "registry": {
      "additionalProperties": true,
      "type": "object",
      "required": [
        "owner",
        "trust_tier",
        "version",
        "profile_path",
        "materialized_package_is_registry_artifact"
      ],
      "properties": {
        "owner": {
          "type": "string"
        },
        "trust_tier": {
          "anyOf": [
            {
              "const": "upstream-owned",
              "type": "string"
            },
            {
              "const": "community",
              "type": "string"
            },
            {
              "const": "unverified",
              "type": "string"
            }
          ]
        },
        "version": {
          "type": "string"
        },
        "install_command": {
          "type": "string"
        },
        "run_command": {
          "type": "string"
        },
        "profile_path": {
          "type": "string"
        },
        "materialized_package_is_registry_artifact": {
          "const": true,
          "type": "boolean"
        }
      }
    },
    "harness": {
      "additionalProperties": true,
      "type": "object",
      "required": [
        "status",
        "case_count"
      ],
      "properties": {
        "status": {
          "anyOf": [
            {
              "const": "pending",
              "type": "string"
            },
            {
              "const": "failed",
              "type": "string"
            },
            {
              "const": "harness_verified",
              "type": "string"
            }
          ]
        },
        "case_count": {
          "type": "number"
        },
        "assertion_count": {
          "type": "number"
        },
        "case_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
