{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.runx.ai/runx/payment/reservation/v1.json",
  "x-runx-packet-id": "runx.payment.reservation.v1",
  "type": "object",
  "properties": {
    "payment_decision": { "type": "object" },
    "reserved_payment_authority": { "type": "object" },
    "authority_decision": { "type": "object" },
    "reservation": { "type": "object" },
    "idempotency": { "type": "object" },
    "spend_capability_ref": {
      "type": "object",
      "properties": {
        "type": { "const": "credential" },
        "uri": { "type": "string", "minLength": 1 }
      },
      "required": ["type", "uri"],
      "additionalProperties": true
    },
    "approval": { "type": "object" },
    "recovery_plan": { "type": "object" },
    "core_requirements": { "type": "array" },
    "open_questions": { "type": "array" }
  },
  "additionalProperties": true
}
