{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.runx.ai/runx/effect/transition/v1.json",
  "x-runx-packet-id": "runx.effect.transition.v1",
  "type": "object",
  "properties": {
    "effect_family": { "type": "string", "minLength": 1 },
    "operation": { "type": "string", "minLength": 1 },
    "expected_version": { "type": "integer", "minimum": 0 },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "event": {
      "type": "object",
      "additionalProperties": true
    },
    "actor_kid": { "type": "string" },
    "moderator_kid": { "type": "string" },
    "posting_id": { "type": "string" },
    "posting": {
      "type": "object",
      "additionalProperties": true
    },
    "screening_notes": { "type": "array" },
    "claim": {
      "type": "object",
      "additionalProperties": true
    },
    "delivery": {
      "type": "object",
      "additionalProperties": true
    },
    "acceptance_window": {
      "type": "object",
      "additionalProperties": true
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": true
    },
    "payout_authorization": {
      "type": "object",
      "additionalProperties": true
    },
    "decision": { "type": "string" },
    "reasons": { "type": "array" },
    "visibility_effect": { "type": "string" },
    "phase": { "type": "string" },
    "victim_kid": { "type": "string" },
    "norm_refs": { "type": "array" },
    "receipt_ref": { "type": "string" },
    "ledger_entries": { "type": "array" },
    "judgment": {
      "type": "object",
      "additionalProperties": true
    },
    "funding": {
      "type": "object",
      "additionalProperties": true
    },
    "clocks": {
      "type": "object",
      "additionalProperties": true
    },
    "stop_conditions": { "type": "array" }
  },
  "required": ["effect_family", "operation"],
  "additionalProperties": true
}
