{
  "schema": "runx.tool.manifest.v1",
  "name": "fs.delete",
  "description": "Delete a file relative to a repository or workspace root.",
  "source": {
    "type": "cli-tool",
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "inputs": {
    "path": {
      "type": "string",
      "required": true,
      "description": "Path to the file relative to repo_root."
    },
    "repo_root": {
      "type": "string",
      "required": false,
      "description": "Repository or workspace root; defaults to fixture, RUNX_CWD, or the current working directory."
    },
    "fixture": {
      "type": "string",
      "required": false,
      "description": "Optional fixture workspace root used during dev and harness execution."
    }
  },
  "output": {
    "packet": "runx.fs.delete.v1",
    "wrap_as": "file_delete"
  },
  "scopes": [
    "fs.write"
  ],
  "runx": {
    "artifacts": {
      "wrap_as": "file_delete"
    }
  },
  "runtime": {
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "source_hash": "sha256:7b9016221e3ef58ab93e3b2172ab15d4e6d1901464bdce9e7976fdfaecda6054",
