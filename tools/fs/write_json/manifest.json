{
  "schema": "runx.tool.manifest.v1",
  "name": "fs.write_json",
  "description": "Write JSON to a file relative to a repository or workspace root.",
  "source": {
    "type": "cli-tool",
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "inputs": {
    "path": {
      "type": "string",
      "required": true,
      "description": "Path to the output file relative to repo_root."
    },
    "data": {
      "type": "json",
      "required": true,
      "description": "JSON-compatible value to serialize."
    },
    "indent": {
      "type": "json",
      "required": false,
      "description": "Optional indentation width. Defaults to 2."
    },
    "repo_root": {
      "type": "string",
      "required": false,
      "description": "Repository or workspace root; defaults to fixture, RUNX_CWD, or the current working directory."
    },
    "fixture": {
      "type": "string",
      "required": false,
      "description": "Optional fixture workspace root used during dev and harness execution."
    }
  },
  "output": {
    "packet": "runx.fs.file_write.v1",
    "wrap_as": "file_write"
  },
  "scopes": [
    "fs.write"
  ],
  "runx": {
    "artifacts": {
      "wrap_as": "file_write"
    }
  },
  "runtime": {
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "source_hash": "sha256:5e3e78bcb89b73fe0968ab7a1048a907d94b24167a5c66adb5e1147e9ff260e8",
  "schema_hash": "sha256:13fee39a142f9661802792007bc9782784eea8032b2a8f1004d83f4d048e7236",
  "toolkit_version": "0.1.4"
}
