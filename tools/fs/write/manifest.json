{
  "schema": "runx.tool.manifest.v1",
  "name": "fs.write",
  "description": "Write a UTF-8 text file relative to a repository or workspace root.",
  "source": {
    "type": "cli-tool",
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "inputs": {
    "path": {
      "type": "string",
      "required": true,
      "description": "Path to the output file relative to repo_root."
    },
    "contents": {
      "type": "json",
      "required": true,
      "description": "UTF-8 string contents to write."
    },
    "repo_root": {
      "type": "string",
      "required": false,
      "description": "Repository or workspace root; defaults to fixture, RUNX_CWD, or the current working directory."
    },
    "fixture": {
      "type": "string",
      "required": false,
      "description": "Optional fixture workspace root used during dev and harness execution."
    }
  },
  "output": {
    "packet": "runx.fs.file_write.v1",
    "wrap_as": "file_write"
  },
  "scopes": [
    "fs.write"
  ],
  "runx": {
    "artifacts": {
      "wrap_as": "file_write"
    }
  },
  "runtime": {
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "source_hash": "sha256:47df108c6a9663513d6cfacf9694ac7e4885ceaf1a7324a6b73b3dc4840b6c76",
  "schema_hash": "sha256:35e39761060690edac08c3d78bab84a2ba2a41959a58f49e4b41fb09b307b23b",
  "toolkit_version": "0.1.4"
}
