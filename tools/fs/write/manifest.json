{
  "schema": "runx.tool.manifest.v1",
  "name": "fs.write",
  "description": "Write a UTF-8 text file relative to a repository or workspace root.",
  "source": {
    "type": "cli-tool",
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "inputs": {
    "path": {
      "type": "string",
      "required": true,
      "description": "Path to the output file relative to repo_root."
    },
    "contents": {
      "type": "json",
      "required": true,
      "description": "UTF-8 string contents to write."
    },
    "repo_root": {
      "type": "string",
      "required": false,
      "description": "Repository or workspace root; defaults to fixture, project, RUNX_CWD, or the current working directory."
    },
    "project": {
      "type": "string",
      "required": false,
      "description": "Optional alias for repo_root used by local harnesses."
    },
    "fixture": {
      "type": "string",
      "required": false,
      "description": "Optional fixture workspace root used during dev and harness execution."
    }
  },
  "output": {
    "packet": "runx.fs.file_write.v1",
    "wrap_as": "file_write"
  },
  "scopes": [
    "fs.write"
  ],
  "runx": {
    "artifacts": {
      "wrap_as": "file_write"
    }
  },
  "runtime": {
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "source_hash": "sha256:6cd30c1545592b1a2cd6fda0899092a7495dfd6afaf520d194cbbb5a7b618f6f",
  "schema_hash": "sha256:3e0be71d53813bf8f9a38af14b0fd74874712f639ccda3b3842e442631198504",
  "toolkit_version": "0.1.3"
}
