{
  "schema": "runx.tool.manifest.v1",
  "name": "sourcey.verify",
  "description": "Verify that a Sourcey build produced an index.html output.",
  "source": {
    "type": "cli-tool",
    "command": "node",
    "args": [
      "./run.mjs"
    ],
    "timeout_seconds": 30,
    "input_mode": "none"
  },
  "inputs": {
    "output_dir": {
      "type": "string",
      "required": true,
      "description": "Output directory produced by Sourcey."
    },
    "index_path": {
      "type": "string",
      "required": false,
      "description": "Explicit index file path; defaults to <output_dir>/index.html."
    },
    "sourcey_build_report": {
      "type": "json",
      "required": false,
      "description": "Optional Sourcey build report; invalid card icon validation blocks verification."
    }
  },
  "scopes": [
    "sourcey.verify"
  ],
  "runx": {
    "artifacts": {
      "wrap_as": "sourcey_verification_report"
    }
  },
  "runtime": {
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "output": {
    "packet": "runx.sourcey.verification.v1",
    "wrap_as": "sourcey_verification_report"
  },
  "source_hash": "sha256:f28d1645ac9d5f6e68c9c005317d66e6a1795961742f3b1792501811d65fa2f4",
  "schema_hash": "sha256:988547124ced9b1f8d9c43f4a354e418ee673cae6ec04056460951119e89ae4d",
  "toolkit_version": "0.0.0"
}
