{
  "schema": "runx.tool.manifest.v1",
  "name": "sourcey.verify",
  "description": "Verify that a Sourcey build produced an index.html output.",
  "source": {
    "type": "cli-tool",
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "inputs": {
    "output_dir": {
      "type": "string",
      "required": true,
      "description": "Output directory produced by the Sourcey build."
    },
    "index_path": {
      "type": "string",
      "required": false,
      "description": "Optional index path relative to output_dir. Defaults to index.html."
    },
    "sourcey_build_report": {
      "type": "json",
      "required": false,
      "artifact": true,
      "description": "Optional Sourcey build report used to carry icon validation results forward."
    }
  },
  "output": {
    "packet": "runx.sourcey.verification.v1",
    "wrap_as": "sourcey_verification_report"
  },
  "scopes": [
    "sourcey.verify"
  ],
  "runx": {
    "artifacts": {
      "wrap_as": "sourcey_verification_report"
    }
  },
  "runtime": {
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "source_hash": "sha256:35c504d5875896680132d6ab920aee5ada9036367646207d8f4c38db482d8095",
  "schema_hash": "sha256:5379c6e1509ab9c6c8a6340564b142d808ecc360e66842a004d93468a45805da",
  "toolkit_version": "0.1.3"
}
