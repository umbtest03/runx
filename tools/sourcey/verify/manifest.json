{
  "schema": "runx.tool.manifest.v1",
  "name": "sourcey.verify",
  "description": "Verify that a Sourcey build produced an index.html output.",
  "source": {
    "type": "cli-tool",
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "inputs": {
    "output_dir": {
      "type": "string",
      "required": true,
      "description": "Output directory produced by the Sourcey build."
    },
    "index_path": {
      "type": "string",
      "required": false,
      "description": "Optional index path relative to output_dir. Defaults to index.html."
    },
    "sourcey_build_report": {
      "type": "json",
      "required": false,
      "artifact": true,
      "description": "Optional Sourcey build report used to carry icon validation results forward."
    }
  },
  "output": {
    "packet": "runx.sourcey.verification.v1",
    "wrap_as": "sourcey_verification_proof"
  },
  "scopes": [
    "sourcey.verify"
  ],
  "runx": {
    "artifacts": {
      "wrap_as": "sourcey_verification_proof"
    }
  },
  "runtime": {
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "source_hash": "sha256:8f8ee91392dd01f66ab1d734ec4d78547016f37681e26d4a9283e73e6c429673",
  "schema_hash": "sha256:2a5ee7012cb4ce1eb5b071c9d5d0ee5dd92733291deff97e8ca475459388c29c",
  "toolkit_version": "0.1.4"
}
