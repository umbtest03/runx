{
  "schema": "runx.tool.manifest.v1",
  "name": "sourcey.package",
  "description": "Package a completed Sourcey run into a reusable Sourcey packet.",
  "source": {
    "type": "cli-tool",
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "inputs": {
    "discovery_report": {
      "type": "json",
      "required": true,
      "artifact": true,
      "description": "Discovery report emitted by the Sourcey discover step."
    },
    "doc_bundle": {
      "type": "json",
      "required": true,
      "artifact": true,
      "description": "Doc bundle emitted by the Sourcey author step."
    },
    "project_brief": {
      "type": "json",
      "required": false,
      "artifact": true,
      "description": "Optional grounded brief supplied to the Sourcey run."
    },
    "sourcey_build_report": {
      "type": "json",
      "required": true,
      "artifact": true,
      "description": "Sourcey build report emitted by sourcey.build."
    },
    "evaluation_report": {
      "type": "json",
      "required": true,
      "artifact": true,
      "description": "Evaluation report emitted by the critique step."
    },
    "revision_bundle": {
      "type": "json",
      "required": true,
      "artifact": true,
      "description": "Revision bundle emitted by the revise step."
    },
    "sourcey_verification_report": {
      "type": "json",
      "required": true,
      "artifact": true,
      "description": "Verification report emitted by sourcey.verify."
    }
  },
  "output": {
    "packet": "runx.sourcey.packet.v1",
    "wrap_as": "sourcey_packet"
  },
  "scopes": [
    "sourcey.verify"
  ],
  "runx": {
    "artifacts": {
      "wrap_as": "sourcey_packet"
    }
  },
  "runtime": {
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "source_hash": "sha256:ce562824f88df2ae51836d900c69f3cc7f910fbe7f8bf53133f6d4923b2f907b",
  "schema_hash": "sha256:513c043cce178e985c7af86690bb058301057ddbd4f3dbc3af06463ec922e8f1",
  "toolkit_version": "0.1.1"
}
