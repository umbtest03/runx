{
  "schema": "runx.tool.manifest.v1",
  "name": "spec.read_declared_files",
  "description": "Read the current contents of files declared in a scafld spec before bounded fix authoring.",
  "source": {
    "type": "cli-tool",
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "inputs": {
    "spec_contents": {
      "type": "string",
      "required": true,
      "description": "Raw scafld spec contents to inspect for declared file paths."
    },
    "repo_root": {
      "type": "string",
      "required": false,
      "description": "Repository root used to resolve declared file paths."
    },
    "fixture": {
      "type": "string",
      "required": false,
      "description": "Optional fixture workspace root used during dev and harness execution."
    }
  },
  "output": {
    "packet": "runx.spec.declared_file_context.v1",
    "wrap_as": "declared_file_context"
  },
  "scopes": [
    "spec.read_declared_files"
  ],
  "runx": {
    "artifacts": {
      "wrap_as": "declared_file_context"
    }
  },
  "runtime": {
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "source_hash": "sha256:732a30fcbe5539d0c888e4a94d01ade5e7cf426cf63cec522f6e236adfa38fb6",
  "schema_hash": "sha256:fdc484586979e2d461117eb1b4355f7ece6a13baa6dabf4f7af8bf2b5764d342",
  "toolkit_version": "0.1.1"
}
