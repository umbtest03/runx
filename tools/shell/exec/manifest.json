{
  "schema": "runx.tool.manifest.v1",
  "name": "shell.exec",
  "description": "Execute an explicit command as a high-risk escape hatch.",
  "source": {
    "type": "cli-tool",
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "inputs": {
    "command": {
      "type": "string",
      "required": true,
      "description": "Executable to invoke."
    },
    "args": {
      "type": "json",
      "required": false,
      "description": "Optional argument array for the command."
    },
    "cwd": {
      "type": "string",
      "required": false,
      "description": "Optional working directory override for the command."
    },
    "repo_root": {
      "type": "string",
      "required": false,
      "description": "Optional repository root used when cwd is not supplied."
    }
  },
  "output": {
    "packet": "runx.shell.execution.v1",
    "wrap_as": "shell_execution"
  },
  "scopes": [
    "shell.exec"
  ],
  "runx": {
    "artifacts": {
      "wrap_as": "shell_execution"
    }
  },
  "runtime": {
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "source_hash": "sha256:ed0f4fbabb4c2c6ea02dab8b57fcc143a54d63a1369fea4fad8ba176315378b2",
  "schema_hash": "sha256:6b798dd3ccd5d80d23c70ee8278f165ddc974eed45b3a056431310890f634371",
  "toolkit_version": "0.1.3"
}
