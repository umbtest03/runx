{
  "schema": "runx.thread_outbox_provider.manifest.v1",
  "protocol_version": "runx.thread_outbox_provider.v1",
  "adapter_id": "thread-provider.github",
  "provider": "github",
  "name": "GitHub issue-to-PR outbox provider",
  "version": "0.1.0",
  "supported_operations": ["push"],
  "transport": {
    "kind": "process",
    "command": "node",
    "args": ["../../../../tools/thread/thread_outbox_provider/github-provider.mjs"]
  },
  "credential_needs": [
    {
      "provider": "github",
      "purpose": "provider_api",
      "profile_id": "github-provider-api-env",
      "delivery_mode": "process_env",
      "required": true,
      "scope_refs": [
        {
          "type": "grant",
          "uri": "runx:grant:github-issues-write"
        }
      ]
    }
  ],
  "receipt_capabilities": {
    "idempotent_push": true,
    "readback": true,
    "stable_provider_event_hash": true
  },
  "redaction_capabilities": {
    "redacts_credentials": true,
    "redacts_provider_payloads": true,
    "supports_redaction_refs": true
  }
}
