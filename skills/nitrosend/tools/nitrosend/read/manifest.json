{
  "schema": "runx.tool.manifest.v1",
  "name": "nitrosend.read",
  "version": "0.2.0",
  "description": "Run one bounded read-only Nitrosend MCP operation and emit redacted provider evidence.",
  "source": {
    "type": "cli-tool",
    "command": "node",
    "args": ["./run.mjs"],
    "sandbox": {
      "profile": "network",
      "cwd_policy": "skill-directory",
      "network": true,
      "writable_paths": [],
      "require_enforcement": false,
      "env_allowlist": []
    }
  },
  "inputs": {
    "operation": {
      "type": "string",
      "required": true,
      "description": "Bounded read operation: status, insights, review_delivery, or import_status."
    },
    "arguments": {
      "type": "json",
      "required": false,
      "description": "Arguments for the selected Nitrosend MCP tool."
    },
    "brand_sid": {
      "type": "string",
      "required": false,
      "description": "Optional public Nitrosend brand SID."
    }
  },
  "scopes": ["nitrosend:read"],
  "output": {
    "packet": "runx.provider_evidence.v1",
    "wrap_as": "provider_evidence"
  }
}
